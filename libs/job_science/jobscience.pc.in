prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/jobscience

Name: jobscience
Description: Science library for JOB (Joseph's Odd Builder)
Version: @PROJECT_VERSION@
Libs: -L${libdir} -ljobscience -ljobthreads -ljobcore -lpthread -latomic -ljobcrypto -ljobnet
Cflags: -I${includedir}
