prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/jobai

Name: jobai
Description: AI library for JOB (Joseph's Odd Builder)
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lpthread -latomic -ljobcore -ljobthreads -lpthread -latomic -ljobcrypto -ljobnet
Cflags: -I${includedir}
