prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/jobcrypto

Name: jobcrypto
Description: Crypto library for JOB (Joseph's Odd Builder)
Version: @PROJECT_VERSION@
Libs: -L${libdir} -ljobcrypto -lpthread -lsodium
Cflags: -I${includedir}
