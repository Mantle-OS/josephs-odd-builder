prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/jobserializerflatbuffer

Name: jobserializerflatbuffer
Description: Flatbuffers Serializer Plugin library for JOB (Joseph's Odd Builder)
Version: @PROJECT_VERSION@
Requires: yaml flatbuffers
Libs: -L${libdir} -ljobserializer -ljobcore -ljobio -ljobthreads -lflatbuffers
Cflags: -I${includedir}
