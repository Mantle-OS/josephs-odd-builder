prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/jobnet

Name: jobnet
Description: Networking library for JOB (Joseph's Odd Builder)
Version: @PROJECT_VERSION@
Requires.private: libcrypto
Libs.private: -lz -lzstd -ldl -pthread
Libs: -L${libdir} -ljobnet -lssl
Cflags: -I${includedir}
