prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/jobio

Name: jobio
Description: IO library for JOB (Joseph's Odd Builder)
Version: @PROJECT_VERSION@
Requires.private: libcrypto
Libs.private: -lz -lzstd -ldl -pthread
Libs: -L${libdir} -ljobio -ludev -lssl
Cflags: -I${includedir}
